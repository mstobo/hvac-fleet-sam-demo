# Copy to a path outside git (e.g. /opt/mqtt5sr/.env) and pass to Compose:
#   docker compose -f deploy/aws/docker-compose.yml --env-file /opt/mqtt5sr/.env up -d
#
# For a full variable list and comments, start from sam/.env.example and merge
# the overrides below (Docker binds services on all interfaces).
#
# ── Docker images (EC2 — required; default mqtt5sr-demo:latest is not on Docker Hub) ─
# MQTT5SR_IMAGE=804666467877.dkr.ecr.us-east-2.amazonaws.com/hvac/fleet/management:latest
# MQTT5SR_JAVA_IMAGE=804666467877.dkr.ecr.us-east-2.amazonaws.com/mqtt5sr-java:latest
# Start without pull: ENV_FILE=.env docker compose -f deploy/aws/docker-compose.yml up -d --pull never

# ── LLM (required for SAM agents that call the planner) ─────────────────────
LLM_SERVICE_ENDPOINT="https://your-llm-endpoint.com"
LLM_SERVICE_API_KEY="your-api-key"
# SAM uses the LiteLLM Python SDK (not raw HTTP). For a LiteLLM proxy/gateway use:
#   litellm_proxy/<model-on-proxy>   e.g. litellm_proxy/azure-gpt-5-mini
# Plain names like azure-gpt-5-mini work for curl/test_llm.py but fail in SAM with
# "LLM Provider NOT provided".
LLM_SERVICE_PLANNING_MODEL_NAME="litellm_proxy/azure-gpt-5-mini"
LLM_SERVICE_GENERAL_MODEL_NAME="litellm_proxy/azure-gpt-5-mini"

# ── Solace ──────────────────────────────────────────────────────────────────
SOLACE_BROKER_URL="wss://your-broker.messaging.solace.cloud:443"
SOLACE_BROKER_VPN="your-vpn"
SOLACE_BROKER_USERNAME="your-username"
SOLACE_BROKER_PASSWORD="your-password"
SOLACE_DEV_MODE="false"

NAMESPACE="mqtt_pipeline_optimizer/"

# Optional: distinct gateway id for fleet-analysis-gateway (separate container from Web UI)
# FLEET_ANALYSIS_GATEWAY_ID="fleet-analysis-gw"

# Optional: generate demo_dashboard.config.json for Apache (see deploy/aws/scripts/gen-dashboard-config.sh)
# DASHBOARD_PUBLIC_HOST="18.x.x.x"
# DASHBOARD_WS_HOST=""   # default: hostname from SOLACE_BROKER_URL
# DASHBOARD_WS_PORT="8443"   # MQTT WebSocket (not 443 from SAM wss URL)

# ── Web UI / platform (0.0.0.0 required inside Docker network + host publish) ─
SESSION_SECRET_KEY="change-this-to-a-long-random-string"
FASTAPI_HOST="0.0.0.0"
FASTAPI_PORT="8000"
FASTAPI_HTTPS_PORT="8443"
SSL_KEYFILE=""
SSL_CERTFILE=""
SSL_KEYFILE_PASSWORD=""
ENABLE_EMBED_RESOLUTION="True"
LOGGING_CONFIG_PATH="configs/logging_config.yaml"

PLATFORM_API_HOST="0.0.0.0"
PLATFORM_API_PORT="8001"
PLATFORM_SERVICE_URL="http://127.0.0.1:8001"

S3_BUCKET_NAME=""
S3_ENDPOINT_URL=""
S3_REGION="us-east-1"

SAM_AUTHORIZATION_CONFIG='{"authorization_service": {"type": "none"}}'

# Pipeline service log verbosity (deadband / sketch / anomaly / chart-writer).
# INFO (default) shows connection state, alerts, periodic counters. DEBUG adds
# per-message FORWARD/SUPPRESS/SKIP/sketched lines — useful for diagnosing
# whether a sensor is even reaching the pipeline. WARNING quiets routine
# activity but keeps publish-drops and errors visible.
# LOG_LEVEL="INFO"

# Chart: Compose sets CHART_QUERY_BASE_URL=http://chart-query:8010 for SAM→chart-query.
# Slack/fleet plot links need a browser-reachable base (NOT chart-query). Set one of:
#   CHART_PUBLIC_BASE_URL="http://YOUR_EC2_PUBLIC_IP:8010"
#   CHART_PUBLIC_BASE_URL="http://YOUR_EC2_PUBLIC_IP/charts"   # if Apache proxies /charts/ → :8010
# Or set DASHBOARD_PUBLIC_HOST (same as gen-dashboard-config.sh); SAM derives http://HOST/charts.
# DASHBOARD_PUBLIC_HOST="18.x.x.x"
# CHART_PUBLIC_BASE_URL="http://18.x.x.x/charts"

# Optional auth for chart-query. When set, EVERY caller must see this value:
#   - chart-query container reads it at startup and rejects unauthenticated requests
#   - sam-control-plane container: fleet_query_tools.py picks it up from this same env_file
#   - dashboard: pass once via ?chartKey=... or via demo_dashboard.config.json -> chartQueryApiKey
#   - Slack-clickable plot URLs: fleet_query_tools appends &key= automatically
# Generate a long random string, e.g.  openssl rand -hex 32
# Leave unset for open access (current default).
# CHART_QUERY_API_KEY=""
# Optional CORS allowlist (comma-separated). Default "*" preserves wide-open behaviour.
# CHART_QUERY_ALLOWED_ORIGINS="https://demo.example.com,http://18.x.x.x"

# ── Slack (optional; use Compose profile `slack`) ───────────────────────────
SLACK_BOT_TOKEN=""
SLACK_APP_TOKEN=""
SLACK_ALERT_CHANNEL="#sensor-alerts"
SLACK_RATE_LIMIT_SECONDS="60"

# ── Java MQTT sample (Compose profile `java`; Paho URL, not WebSocket) ───────
# Leave unset to use defaults in src/main/java/MqttConfig.java (not recommended in prod).
# MQTT_BROKER_URL="ssl://your-broker.messaging.solace.cloud:8883"
# MQTT_USERNAME="your-username"
# MQTT_PASSWORD="your-password"
# JAVA_MAIN_CLASS="MQTT5Publisher"
# Schema registry / SERDES: off by default (plain JSON). Do not set unless you need validation:
# MQTT_JSON_SERDES_ENABLED=false
# MQTT_JSON_PUBLISH_WITH_SERDES=false
