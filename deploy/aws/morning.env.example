# Copy to morning.env (same directory) and adjust. morning.env is gitignored.
#
#   cp deploy/aws/morning.env.example deploy/aws/morning.env
#
# Then from repo root:
#   ./deploy/aws/scripts/morning-deploy-to-aws.sh

# Required for ECR push
AWS_REGION=us-east-1
ECR_REPOSITORY=mqtt5sr-demo

# Optional
# ECR_REPOSITORY_JAVA=mqtt5sr-java
# IMAGE_TAG=latest

# Build and push the Java image too (set to 0 for Python/SAM only)
# WITH_JAVA=1

# After push, SSH to EC2 and run compose pull + up (leave empty to only push from laptop)
# IMPORTANT: These variables must be in THIS file at deploy/aws/morning.env (not .env, not repo root).
# Lines must be uncommented — a leading # means EC2_HOST is unset and SSH is skipped.
# EC2_HOST=ec2-1-2-3-4.compute-1.amazonaws.com
# EC2_USER=ec2-user
# EC2_KEY=/full/path/to/your-key.pem
# EC2_REPO_PATH must exist on the server (clone repo here first). Default matches ec2-user-data.sh.
# EC2_REPO_PATH=/opt/mqtt5sr/mqtt5SRDemo

# Compose profiles on the server: comma-separated (e.g. java or slack,java)
# COMPOSE_PROFILES=java
