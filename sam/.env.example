# ─────────────────────────────────────────────────────────────────────────────
# Solace Agent Mesh Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# LLM Service Configuration
# ─────────────────────────────────────────────────────────────────────────────
LLM_SERVICE_ENDPOINT="https://your-llm-endpoint.com"
LLM_SERVICE_API_KEY="your-api-key"
# Model name must match what your LiteLLM *team* is allowed to call (not every id in GET /models).
# Maas/Solace teams often only allow the group alias:
LLM_SERVICE_PLANNING_MODEL_NAME="production-models"
LLM_SERVICE_GENERAL_MODEL_NAME="production-models"
# If test_llm.py returns team_model_access_denied, do NOT use openai_proxy/... or litellm_proxy/...
# until your admin confirms that prefix is required for SAM on your gateway.
# Optional: test_llm.py auto-retries this when the primary model fails:
# LLM_TEAM_MODEL_GROUP="production-models"

# ─────────────────────────────────────────────────────────────────────────────
# Solace Broker Configuration
# ─────────────────────────────────────────────────────────────────────────────
SOLACE_BROKER_URL="wss://your-broker.messaging.solace.cloud:443"
SOLACE_BROKER_VPN="your-vpn"
SOLACE_BROKER_USERNAME="your-username"
SOLACE_BROKER_PASSWORD="your-password"
SOLACE_DEV_MODE="false"

# Pipeline MQTT path includes broker/datacenter id (Hub = central cloud; DC1 / DC2 = spokes).
# Topics look like: dc/<DC_BROKER_SITE>/v1/raw/... and dc/<DC_BROKER_SITE>/v1/pipeline/...
# DC_BROKER_SITE="Hub"
# On the hub, ingest raw from all bridged spokes (optional):
# DC_PIPELINE_MULTISITE_RAW="true"

# ─────────────────────────────────────────────────────────────────────────────
# SAM Namespace
# ─────────────────────────────────────────────────────────────────────────────
NAMESPACE="mqtt_pipeline_optimizer/"

# Local laptop: avoid queue clashes with AWS/another SAM on the same Solace Cloud broker.
# start_demo_stack.sh exports these defaults when unset:
# USE_TEMPORARY_QUEUES="true"
# FLEET_ANALYSIS_GATEWAY_ID="fleet-analysis-gw-local"
# SLACK_GATEWAY_ID="slack-gw-local"
# WEBUI_GATEWAY_ID="webui-gw-local"
# Or use a dedicated namespace (no shared MQTT with remote demo):
# NAMESPACE="mqtt_pipeline_optimizer-local/"

# ─────────────────────────────────────────────────────────────────────────────
# Web UI Configuration
# ─────────────────────────────────────────────────────────────────────────────
SESSION_SECRET_KEY="change-this-secret-key"
FASTAPI_HOST="127.0.0.1"
FASTAPI_PORT="8000"
FASTAPI_HTTPS_PORT="8443"
SSL_KEYFILE=""
SSL_CERTFILE=""
SSL_KEYFILE_PASSWORD=""
ENABLE_EMBED_RESOLUTION="True"
LOGGING_CONFIG_PATH="configs/logging_config.yaml"

# ─────────────────────────────────────────────────────────────────────────────
# Platform Service
# ─────────────────────────────────────────────────────────────────────────────
PLATFORM_API_HOST="127.0.0.1"
PLATFORM_API_PORT="8001"
PLATFORM_SERVICE_URL="http://127.0.0.1:8001"

# Chart query HTTP (series / plotly-spec / plotly-html). SAM tools call this from the same machine by default.
# CHART_QUERY_BASE_URL="http://127.0.0.1:8010"
# Optional: URLs embedded in Slack / fleet reports use this host when set (Docker: public host IP + published 8010).
# CHART_PUBLIC_BASE_URL="https://your-demo-host.example.com:8010"

# ─────────────────────────────────────────────────────────────────────────────
# S3 (Optional - for artifact storage)
# ─────────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=""
S3_ENDPOINT_URL=""
S3_REGION="us-east-1"

# ─────────────────────────────────────────────────────────────────────────────
# Authorization
# ─────────────────────────────────────────────────────────────────────────────
SAM_AUTHORIZATION_CONFIG='{"authorization_service": {"type": "none"}}'

# ─────────────────────────────────────────────────────────────────────────────
# Slack Integration (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# To enable Slack integration:
# 1. Create a Slack App at https://api.slack.com/apps
# 2. Enable Socket Mode
# 3. Add OAuth scopes: app_mentions:read, chat:write, channels:history, 
#    groups:history, im:history, users:read, users:read.email
# 4. Subscribe to events: app_mention, message.channels, message.groups, message.im
# 5. Install to workspace and copy tokens below

# Bot token (starts with xoxb-)
SLACK_BOT_TOKEN="xoxb-your-bot-token"

# App token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN="xapp-your-app-token"

# Channel for critical alerts (must invite bot to this channel)
SLACK_ALERT_CHANNEL="#sensor-alerts"

# Rate limit: minimum seconds between alerts for the same sensor
SLACK_RATE_LIMIT_SECONDS="60"
